class SystemPanel extends StatelessWidget {
  final VoidCallback onBack;
  final bool isDarkMode;
  final ValueChanged<bool> onThemeChanged;

  const SystemPanel({
    super.key,
    required this.onBack,
    required this.isDarkMode,
    required this.onThemeChanged,
  });

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: Colors.transparent,
      appBar: AppBar(
        leading: IconButton(
          icon: const Icon(Icons.arrow_back),
          onPressed: onBack,
        ),
        title: const Text('Local Command & Parameters'),
        centerTitle: true,
        backgroundColor: Colors.transparent,
      ),
      body: ListView(
        padding: const EdgeInsets.all(16),
        children: [
          _buildThemeTile(),
          const Divider(),
          _buildSystemTile(Icons.storage_rounded, 'Archived Local Dialect Oral Histories', 'Indexing: 42 recordings'),
          const Divider(),
          _buildSystemTile(Icons.cloud_sync, 'Open-Meteo API Relays', 'Active Synchronization'),
          const Divider(),
          _buildSystemTile(Icons.security, 'Data Sovereignty Compliance', 'Decentralized local storage'),
        ],
      ),
    );
  }

  Widget _buildThemeTile() {
    return ListTile(
      leading: Container(
        padding: const EdgeInsets.all(8),
        decoration: BoxDecoration(
          color: Colors.green.withOpacity(0.2),
          borderRadius: BorderRadius.circular(8),
        ),
        child: Icon(isDarkMode ? Icons.dark_mode : Icons.light_mode),
      ),
      title: const Text('Interface Dark Mode', style: TextStyle(fontWeight: FontWeight.w500)),
      subtitle: const Text('Toggles between standard Light and High-Vis Dark Theme'),
      trailing: Switch(
        value: isDarkMode,
        onChanged: onThemeChanged,
        activeColor: Colors.green,
      ),
    );
  }

  Widget _buildSystemTile(IconData icon, String title, String subtitle) {
    return ListTile(
      leading: Container(
        padding: const EdgeInsets.all(8),
        decoration: BoxDecoration(
          color: Colors.green.withOpacity(0.1),
          borderRadius: BorderRadius.circular(8),
        ),
        child: Icon(icon),
      ),
      title: Text(title, style: const TextStyle(fontWeight: FontWeight.w500)),
      subtitle: Text(subtitle, style: const TextStyle(fontSize: 13)),
    );
  }
}
