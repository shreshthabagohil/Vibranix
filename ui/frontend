                  onPressed: () => setState(() => _showPollinators = true),
                  style: ElevatedButton.styleFrom(
                    backgroundColor: _showPollinators ? Colors.green : (isDark ? Colors.grey[800] : Colors.white),
                    foregroundColor: _showPollinators ? Colors.white : (isDark ? Colors.white70 : Colors.black),
                  ),
                  child: const Text('Pollinators Trace'),
                ),
              ),
              const SizedBox(width: 12),
              Expanded(
                child: ElevatedButton(
                  onPressed: () => setState(() => _showPollinators = false),
                  style: ElevatedButton.styleFrom(
                    backgroundColor: !_showPollinators ? Colors.red : (isDark ? Colors.grey[800] : Colors.white),
                    foregroundColor: !_showPollinators ? Colors.white : (isDark ? Colors.white70 : Colors.black),
                  ),
                  child: const Text('Pest Invasion'),
                ),
              ),
            ],
          ),
          const SizedBox(height: 8),
          Row(
            mainAxisAlignment: MainAxisAlignment.spaceBetween,
            children: [
              TextButton.icon(
                onPressed: () => setState(() => _mapOffset = Offset.zero),
                icon: const Icon(Icons.center_focus_strong, color: Colors.blue),
                label: const Text('Center View'),
              ),
              if (widget.userMarkedPoints.isNotEmpty)
                TextButton.icon(
                  onPressed: () => setState(() => widget.userMarkedPoints.clear()),
                  icon: const Icon(Icons.clear, color: Colors.red),
                  label: const Text('Clear Markers', style: TextStyle(color: Colors.red)),
                ),
            ],
          ),
        ],
      ),
    );
  }

  Widget _buildGridLines(bool isDark) {
    return GridView.builder(
      physics: const NeverScrollableScrollPhysics(),
      gridDelegate: const SliverGridDelegateWithFixedCrossAxisCount(
        crossAxisCount: 10,
      ),
      itemCount: 100,
      itemBuilder: (context, index) => Container(
        decoration: BoxDecoration(border: Border.all(color: isDark ? Colors.white10 : Colors.black12.withOpacity(0.04))),
      ),
    );
  }

  Widget _buildMarker(IconData icon, Color color) {
    return Container(
      padding: const EdgeInsets.all(4),
      decoration: BoxDecoration(color: color.withOpacity(0.2), shape: BoxShape.circle),
      child: Icon(icon, color: color, size: 24),
    );
  }
}

