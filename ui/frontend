// --- Dynamic Particle Modeling ---
class Particle {
  Offset position;
  Offset velocity;
  double opacity;
  double radius;
  final double maxAge;
  double age = 0;
  double rotation;
  double rotationSpeed;

  Particle({
    required this.position,
    required this.velocity,
    required this.opacity,
    required this.radius,
    this.rotation = 0,
    this.rotationSpeed = 0,
    this.maxAge = 100,
  });

  bool update() {
    position += velocity;
    rotation += rotationSpeed;
    age++;
    opacity = math.max(0.0, 1.0 - (age / maxAge));
    return age < maxAge;
  }
}

class MainScreen extends StatefulWidget {
  final bool isDarkMode;
  final ValueChanged<bool> onThemeChanged;

  const MainScreen({
    super.key,
    required this.isDarkMode,
    required this.onThemeChanged,
  });

  @override
  State<MainScreen> createState() => _MainScreenState();
}

class _MainScreenState extends State<MainScreen> with TickerProviderStateMixin {
  int _selectedIndex = 0;
  bool _showSystem = false;

  final List<ColoredMarker> _globalMarkedPoints = [];

  // Particle Viewport State
  final List<Particle> _particles = [];
  Offset _cursorPosition = Offset.zero;
  late AnimationController _particleEngine;
  final math.Random _random = math.Random();

  Timer? _restTimer;

  // Lifted state for season tracking
  double _timelineValue = 0.2;

  @override
  void initState() {
    super.initState();
    _particleEngine = AnimationController(
      vsync: this,
      duration: const Duration(seconds: 1),
    )..addListener(_tickParticles)..repeat();
  }

  @override
  void dispose() {
    _particleEngine.dispose();
    _restTimer?.cancel();
    super.dispose();
  }

  void _onCursorMoved(Offset newPosition) {
    _restTimer?.cancel();

    setState(() {
      _cursorPosition = newPosition;
    });

    _restTimer = Timer(const Duration(milliseconds: 1000), () {
      if (mounted) {
        setState(() {
          _cursorPosition = Offset.zero;
        });
      }
    });
  }

  void _tickParticles() {
    if (!mounted) return;

    setState(() {
      bool isSpring = _timelineValue <= 0.33;
      bool isAutumn = _timelineValue > 0.33 && _timelineValue <= 0.66;
      bool isWinter = _timelineValue > 0.66;

      if (_cursorPosition != Offset.zero) {
        for (int i = 0; i < 2; i++) {
          _particles.add(
            Particle(
              position: _cursorPosition,
              velocity: Offset(
                (_random.nextDouble() - 0.5) * 4.0,
                (_random.nextDouble() - 0.5) * 4.0,
              ),
              opacity: 0.8,
              radius: (isSpring || isAutumn || isWinter) 
                  ? _random.nextDouble() * 6.0 + 5.0 
                  : _random.nextDouble() * 5.0 + 3.0,
              rotation: _random.nextDouble() * math.pi * 2,
              rotationSpeed: (_random.nextDouble() - 0.5) * 0.1,
              maxAge: 40,
            ),
          );
        }
      }

      if (_random.nextDouble() < 0.15) {
        _particles.add(
          Particle(
            position: Offset(
              _random.nextDouble() * MediaQuery.of(context).size.width,
              MediaQuery.of(context).size.height,
            ),
            velocity: Offset((_random.nextDouble() - 0.5) * 1.0, -1.6),
            opacity: 0.3,
            radius: (isSpring || isAutumn || isWinter) 
                ? _random.nextDouble() * 8.0 + 6.0 
                : _random.nextDouble() * 7.0 + 4.0,
            rotation: _random.nextDouble() * math.pi * 2,
            rotationSpeed: (_random.nextDouble() - 0.5) * 0.05,
            maxAge: 150,
          ),
        );
      }

      _particles.removeWhere((p) => !p.update());
    });
  }

  void _onItemTapped(int index) {
    setState(() {
      _selectedIndex = index;
    });
  }

  Color _getSeasonalColor({
    required Color spring,
    required Color summer,
    required Color autumn,
    required Color winter,
  }) {
    if (_timelineValue <= 0.33) {
      double t = _timelineValue / 0.33;
      return Color.lerp(spring, summer, t.clamp(0.0, 1.0))!;
    } else if (_timelineValue <= 0.66) {
      double t = (_timelineValue - 0.33) / 0.33;
      return Color.lerp(summer, autumn, t.clamp(0.0, 1.0))!;
    } else {
      double t = (_timelineValue - 0.66) / 0.34;
      return Color.lerp(autumn, winter, t.clamp(0.0, 1.0))!;
    }
  }

  @override
  Widget build(BuildContext context) {
    Widget activeView;
    if (_showSystem) {
      activeView = SystemPanel(
        onBack: () => setState(() => _showSystem = false),
        isDarkMode: widget.isDarkMode,
        onThemeChanged: widget.onThemeChanged,
      );
    } else {
      final List<Widget> _screens = [
        GrowthTimelineScreen(
          value: _timelineValue,
          onChanged: (val) => setState(() => _timelineValue = val),
        ),
        const ListenScreen(),
        HeatmapScreen(userMarkedPoints: _globalMarkedPoints),
        const AdvisorScreen(),
        const ProfileScreen(),
      ];

      activeView = Scaffold(
        backgroundColor: Colors.transparent,
        appBar: AppBar(
          title: const Text(
            'Echo-Sentinel',
            style: TextStyle(fontWeight: FontWeight.bold, letterSpacing: 0.5),
          ),
          centerTitle: true,
          elevation: 0,
          backgroundColor: Colors.transparent,
          actions: [
            IconButton(
              icon: const Icon(Icons.settings_outlined),
              onPressed: () => setState(() => _showSystem = true),
            )
          ],
        ),
        body: SafeArea(
          child: Center(
            child: ConstrainedBox(
              constraints: const BoxConstraints(maxWidth: 400),
              child: _screens[_selectedIndex],
            ),
          ),
        ),
        bottomNavigationBar: BottomNavigationBar(
          type: BottomNavigationBarType.fixed,
          currentIndex: _selectedIndex,
          onTap: _onItemTapped,
          selectedItemColor: Colors.green[700],
          unselectedItemColor: Colors.grey[500],
          elevation: 8,
          selectedLabelStyle: const TextStyle(fontWeight: FontWeight.w600, fontSize: 12),
          unselectedLabelStyle: const TextStyle(fontSize: 12),
          items: const [
            BottomNavigationBarItem(icon: Icon(Icons.timeline_rounded), label: 'Timeline'),
            BottomNavigationBarItem(icon: Icon(Icons.graphic_eq_outlined), activeIcon: Icon(Icons.graphic_eq), label: 'Listen'),
            BottomNavigationBarItem(icon: Icon(Icons.map_outlined), activeIcon: Icon(Icons.map), label: 'Map'),
            BottomNavigationBarItem(icon: Icon(Icons.psychology_outlined), activeIcon: Icon(Icons.psychology), label: 'Advisor'),
            BottomNavigationBarItem(icon: Icon(Icons.person_outline), activeIcon: Icon(Icons.person), label: 'Profile'),
          ],
        ),
      );
    }

    final baseBgColor = Theme.of(context).scaffoldBackgroundColor;

    final targetBgColor = _getSeasonalColor(
      spring: const Color(0xFFFCE4EC), 
      summer: const Color(0xFFFFF9C4), 
      autumn: const Color(0xFFE8F5E9), 
      winter: const Color(0xFFE1F5FE), 
    );

    final particleColor = _getSeasonalColor(
      spring: const Color(0xFFFFF176), 
      summer: Colors.orange,
      autumn: const Color(0xFFD7CCC8), 
      winter: Colors.white,
    );

    return MouseRegion(
      onHover: (event) => _onCursorMoved(event.localPosition),
      onExit: (_) => setState(() => _cursorPosition = Offset.zero),
      child: Listener(
        onPointerMove: (event) => _onCursorMoved(event.localPosition),
        onPointerCancel: (_) => setState(() => _cursorPosition = Offset.zero),
        child: Stack(
          children: [
            Positioned.fill(
              child: AnimatedContainer(
                duration: const Duration(milliseconds: 300),
                color: widget.isDarkMode ? baseBgColor : targetBgColor,
              ),
            ),
            Positioned.fill(
              child: CustomPaint(
                painter: BackgroundPainter(
                  particles: _particles,
                  isDark: widget.isDarkMode,
                  seasonColor: particleColor,
                  timeline: _timelineValue,
                ),
              ),
            ),
            Positioned.fill(child: activeView),
          ],
        ),
      ),
    );
  }
}

class BackgroundPainter extends CustomPainter {
  final List<Particle> particles;
  final bool isDark;
  final Color seasonColor;
  final double timeline;

  BackgroundPainter({
    required this.particles,
    required this.isDark,
    required this.seasonColor,
    required this.timeline,
  });

  @override
  void paint(Canvas canvas, Size size) {
    final paint = Paint()..style = PaintingStyle.fill;
    bool isSpring = timeline <= 0.33;
    bool isAutumn = timeline > 0.33 && timeline <= 0.66;
    bool isWinter = timeline > 0.66;

    for (var particle in particles) {
      paint.color = (isDark ? Colors.lightGreenAccent : seasonColor)
          .withOpacity(particle.opacity);

      if (isSpring && !isDark) {
        canvas.save();
        canvas.translate(particle.position.dx, particle.position.dy);
        canvas.rotate(particle.rotation);

        paint.color = const Color(0xFFFFF176).withOpacity(particle.opacity);

        for (int i = 0; i < 4; i++) {
          canvas.save();
          canvas.rotate(i * math.pi / 2);
          canvas.drawOval(
            Rect.fromCenter(
              center: Offset(particle.radius, 0),
              width: particle.radius * 2,
              height: particle.radius,
            ),
            paint,
          );
          canvas.restore();
        }

        paint.color = Colors.orangeAccent.withOpacity(particle.opacity);
        canvas.drawCircle(Offset.zero, particle.radius * 0.4, paint);
        canvas.restore();
      } else if (isAutumn && !isDark) {
        canvas.save();
        canvas.translate(particle.position.dx, particle.position.dy);
        canvas.rotate(particle.rotation);

        final leafPath = Path();
        leafPath.moveTo(0, 0);
        leafPath.quadraticBezierTo(particle.radius * 1.5, -particle.radius, 0, -particle.radius * 2);
        leafPath.quadraticBezierTo(-particle.radius * 1.5, -particle.radius, 0, 0);
        leafPath.close();

        canvas.drawPath(leafPath, paint);
        canvas.restore();
      } else if (isWinter && !isDark) {
        canvas.save();
        canvas.translate(particle.position.dx, particle.position.dy);
        canvas.rotate(particle.rotation);

        final strokePaint = Paint()
          ..color = Colors.white.withOpacity(particle.opacity)
          ..style = PaintingStyle.stroke
          ..strokeWidth = 2.0;

        for (int i = 0; i < 6; i++) {
          canvas.save();
          canvas.rotate(i * math.pi / 3);
          canvas.drawLine(Offset.zero, Offset(particle.radius * 1.2, 0), strokePaint);
          
          canvas.drawLine(Offset(particle.radius * 0.8, 0), Offset(particle.radius * 1.0, particle.radius * 0.3), strokePaint);
          canvas.drawLine(Offset(particle.radius * 0.8, 0), Offset(particle.radius * 1.0, -particle.radius * 0.3), strokePaint);
          canvas.restore();
        }

        canvas.restore();
      } else {
        canvas.drawCircle(particle.position, particle.radius, paint);
      }
    }
  }

  @override
  bool shouldRepaint(covariant CustomPainter oldDelegate) => true;
}

