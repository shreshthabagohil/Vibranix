    required this.onChanged,
  });

  @override
  State<GrowthTimelineScreen> createState() => _GrowthTimelineScreenState();
}

class _GrowthTimelineScreenState extends State<GrowthTimelineScreen> {
  final double _dialSize = 250.0; // The diameter of the circular track

  String get _growthStage {
    if (widget.value < 0.25) return "Seedling";
    if (widget.value < 0.5) return "Vegetative";
    if (widget.value < 0.75) return "Flowering";
    return "Harvest Ready";
  }

  /// Calculates the drag offset to an angle, translating it into a progress value (0 to 1)
  void _calculateAngle(Offset localPosition) {
    final center = Offset(_dialSize / 2, _dialSize / 2);
    final dx = localPosition.dx - center.dx;
    final dy = localPosition.dy - center.dy;

    // Flutter atan2 starts at right-middle (0 rad) -> downwards (pi/2) -> left (pi)
    // We adjust it by -pi/2 so 0 radians starts at the top (North)
    double angle = math.atan2(dy, dx) + math.pi / 2;

    if (angle < 0) {
      angle += 2 * math.pi;
    }

    // Convert angle to percentage 0.0 to 1.0
    double percent = angle / (2 * math.pi);
    widget.onChanged(percent.clamp(0.0, 1.0));
  }

  @override
  Widget build(BuildContext context) {
    bool isDark = Theme.of(context).brightness == Brightness.dark;

    return Padding(
      padding: const EdgeInsets.all(20.0),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          const Text('Growth Timeline', style: TextStyle(fontSize: 24, fontWeight: FontWeight.bold)),
          const Text('Drag the circular track to visualize crop lifecycle & seasons.', style: TextStyle(color: Colors.grey)),
          const Spacer(),
          Center(
            child: Stack(
              alignment: Alignment.center,
              children: [
                // Custom Paint for Circular Slider UI
                CustomPaint(
                  size: Size(_dialSize, _dialSize),
                  painter: CircularDialPainter(
                    percent: widget.value,
                    trackColor: isDark ? Colors.grey[800]! : Colors.grey[300]!,
                    activeColor: Colors.green[700]!,
                  ),
                ),
                
                // Central Animated Icon
                AnimatedContainer(
                  duration: const Duration(milliseconds: 500),
                  height: _dialSize - 90,
                  width: _dialSize - 90,
                  decoration: BoxDecoration(
                    color: isDark ? Colors.grey[850] : Colors.white,
                    shape: BoxShape.circle,
                    boxShadow: const [BoxShadow(color: Colors.black12, blurRadius: 10)],
                  ),
                  child: Icon(
                    widget.value < 0.5 ? Icons.eco : Icons.local_florist,
                    size: 70 + (40 * widget.value),
                    color: Colors.green[700],
                  ),
                ),

                // Invisible gesture interceptor layered exactly over the painted track
                SizedBox(
                  width: _dialSize,
                  height: _dialSize,
                  child: GestureDetector(
                    onPanUpdate: (details) => _calculateAngle(details.localPosition),
                    onPanDown: (details) => _calculateAngle(details.localPosition),
                  ),
                ),
              ],
            ),
          ),
          const Spacer(),
          
          // Season & Stage Descriptor 
          Row(
            mainAxisAlignment: MainAxisAlignment.spaceBetween,
            children: [
              Text('Stage: $_growthStage', style: const TextStyle(fontWeight: FontWeight.bold, fontSize: 18)),
              Icon(Icons.timelapse, color: Colors.green[700]),
            ],
          ),
          const SizedBox(height: 10),
          const Row(
            mainAxisAlignment: MainAxisAlignment.spaceBetween,
            children: [
              Text('🌱 Spring (North)', style: TextStyle(fontSize: 12, fontWeight: FontWeight.w600)),
              Text('🍂 Autumn (South)', style: TextStyle(fontSize: 12, fontWeight: FontWeight.w600)),
            ],
          ),
          const SizedBox(height: 20),
        ],
      ),
    );
  }
}

class CircularDialPainter extends CustomPainter {
  final double percent;
  final Color trackColor;
  final Color activeColor;

  CircularDialPainter({
    required this.percent,
    required this.trackColor,
    required this.activeColor,
  });

  @override
  void paint(Canvas canvas, Size size) {
    final center = Offset(size.width / 2, size.height / 2);
    final radius = size.width / 2 - 10;
    const strokeWidth = 14.0;

    // 1. Background Arc (Unfilled season wheel)
    final bgPaint = Paint()
      ..color = trackColor
      ..style = PaintingStyle.stroke
      ..strokeWidth = strokeWidth;
    canvas.drawCircle(center, radius, bgPaint);

    // 2. Active Progress Arc (Filled season wheel from North)
    final progressPaint = Paint()
      ..color = activeColor
      ..style = PaintingStyle.stroke
      ..strokeWidth = strokeWidth
      ..strokeCap = StrokeCap.round;

    final sweepAngle = 2 * math.pi * percent;
    // -math.pi / 2 shifts start position to North (Top)
    canvas.drawArc(
      Rect.fromCircle(center: center, radius: radius),
      -math.pi / 2,
      sweepAngle,
      false,
      progressPaint,
    );

    // 3. Thumb Dragger Handle Indicator
    final handleAngle = sweepAngle - math.pi / 2;
    final handleOffset = Offset(
      center.dx + radius * math.cos(handleAngle),
      center.dy + radius * math.sin(handleAngle),
    );

    final handlePaint = Paint()
      ..color = Colors.white
      ..style = PaintingStyle.fill;

    final handleBorderPaint = Paint()
      ..color = activeColor
      ..style = PaintingStyle.stroke
      ..strokeWidth = 3.0;

    canvas.drawCircle(handleOffset, 14, handlePaint);
    canvas.drawCircle(handleOffset, 14, handleBorderPaint);
  }

  @override
  bool shouldRepaint(covariant CustomPainter oldDelegate) => true;
}

